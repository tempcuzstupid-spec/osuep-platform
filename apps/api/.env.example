# Required
DATABASE_URL=postgresql://user:pass@host:5432/osuep?sslmode=require
SESSION_SECRET=replace-with-32-byte-random-hex
COOKIE_SECRET=replace-with-32-byte-random-hex

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM="One Stop Uniforms <no-reply@one-stop-uniforms.com>"
EMAIL_REPLY_TO=support@one-stop-uniforms.com

# CORS — what the web app lives at
WEB_ORIGIN=http://localhost:3000

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Public base URL of this API (used in emails, password reset links)
API_PUBLIC_URL=http://localhost:4000
